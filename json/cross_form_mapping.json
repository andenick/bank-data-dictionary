  "prefix_mappings": {
    "FR_Y9C_to_Call_Report": {
      "BHCK": "RCFD",
      "BHCM": "RCON",
      "BHCT": "RCFD",
      "BHCFA": "RCFAA",
      "BHCA": "RCFA",
      "BHCAP": "RCFAP",
      "BHCAA": "RCFAA"
    },
    "notes": "Item numbers typically remain the same; only prefix changes. BHCM maps to RCON (domestic) while BHCK/BHCT map to RCFD (total/foreign)."
  },

  "validation_checks": [
    {
      "check_id": "XF001",
      "description": "CET1 consistency across Y-9C and Call Report",
      "formula": "BHCAP859 should equal sum of subsidiary RCFAP859 (with eliminations)",
      "severity": "CRITICAL"
    },
    {
      "check_id": "XF002",
      "description": "Total assets consolidation",
      "formula": "BHCT2170 should equal sum of subsidiary RCFD2170 (with eliminations)",
      "severity": "CRITICAL"
    },
    {
      "check_id": "XF003",
      "description": "Trading assets match across schedules",
      "formula": "Y-9C HC.5 = Y-9C HC-D.12 = Sum(Call Report RC.5)",
      "severity": "HIGH"
    },
    {
      "check_id": "XF004",
      "description": "Derivatives fair value reconciliation",
      "formula": "HC-D.11 must reconcile to HC-L fair values",
      "severity": "CRITICAL"
    },
    {
      "check_id": "XF005",
      "description": "Capital ratios consistent across Pillar 3",
      "formula": "Y-9C ratios should match Pillar 3 KM1 disclosure",
      "severity": "HIGH"
    }
  ]
