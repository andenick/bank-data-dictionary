  "validation_rules": [
    {
      "rule_id": "V001",
      "name": "Trading Assets Balance",
      "formula": "HC Item 5 == HC-D Item 12",
      "mdrm_check": "BHCT3545 (both places)"
    },
    {
      "rule_id": "V002",
      "name": "Trading Liabilities Balance",
      "formula": "HC Item 15 == HC-D Item 15",
      "mdrm_check": "BHCT3548 (both places)"
    },
    {
      "rule_id": "V003",
      "name": "Derivatives Positive FV Reconciliation",
      "formula": "HC-D Item 11 == Sum(HC-L Trading Positive FV) + Sum(HC-L Non-Trading Positive FV)",
      "mdrm_check": "BHCT3543 == (8733+8734+8735+8736) + (8741+8742+8743+8744)"
    },
    {
      "rule_id": "V004",
      "name": "Derivatives Negative FV Reconciliation",
      "formula": "HC-D Item 14 == Sum(HC-L Trading Negative FV) + Sum(HC-L Non-Trading Negative FV)",
      "mdrm_check": "BHCT3547 == (8737+8738+8739+8740) + (8745+8746+8747+8748)"
    },
    {
      "rule_id": "V005",
      "name": "Total Capital Composition",
      "formula": "Total Capital == Tier 1 + Tier 2",
      "mdrm_check": "BHCA3792 == BHCA8274 + BHCA5311"
    }
  ]
