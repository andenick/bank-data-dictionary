  "capital_reconciliation": {
    "total_capital": {
      "formula": "Tier 1 Capital + Tier 2 Capital",
      "result_mdrm": "BHCA3792",
      "components": {
        "tier1": "BHCA8274",
        "tier2": "BHCA5311"
      }
    },
    "tier1_capital": {
      "formula": "CET1 Capital + Additional Tier 1",
      "result_mdrm": "BHCA8274",
      "components": {
        "cet1": "BHCAP859",
        "at1": "BHCAA227"
      }
    },
    "ratios": {
      "cet1_ratio": {"formula": "BHCAP859 / BHCAA223", "minimum": "4.5%"},
      "tier1_ratio": {"formula": "BHCA8274 / BHCAA223", "minimum": "6.0%"},
      "total_capital_ratio": {"formula": "BHCA3792 / BHCAA223", "minimum": "8.0%"}
    }
  },

